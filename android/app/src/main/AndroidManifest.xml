<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet permission (required) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required for Android 13+ push notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Vibration for notifications -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:label="OneSignal Demo"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!--
            ════════════════════════════════════════════════════════
            OneSignal — small (status-bar) icon
            Must be a WHITE + TRANSPARENT PNG (no colour).
            Place it at:
              android/app/src/main/res/drawable/ic_stat_onesignal_default.png
            ════════════════════════════════════════════════════════
        -->
        <meta-data
            android:name="com.onesignal.NotificationIcon"
            android:resource="@drawable/ic_stat_onesignal_default" />

        <!-- Brand accent colour shown behind the small icon -->
        <meta-data
            android:name="com.onesignal.NotificationAccentColor"
            android:value="FFFF5722" />

        <!--
            ════════════════════════════════════════════════════════
            Default notification channel used by OneSignal.
            The channel ID here must match android_channel_id
            sent from index.js  →  "new_orders_channel"
            ════════════════════════════════════════════════════════
        -->
        <meta-data
            android:name="com.onesignal.NotificationChannelId"
            android:value="new_orders_channel" />

        <!-- Don't delete the meta-data below. Flutter needs this. -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- OneSignal Notification Service Extension -->
        <service
            android:name="com.onesignal.notifications.services.OSRemoteNotificationReceivedHandler"
            android:permission="android.permission.BIND_JOB_SERVICE"
            android:exported="false"
            tools:ignore="MissingClass">
            <intent-filter>
                <action android:name="com.onesignal.NotificationExtender"/>
            </intent-filter>
        </service>

    </application>

</manifest>